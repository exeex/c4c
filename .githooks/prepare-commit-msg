#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?missing commit message file}"
source_type="${2-}"

repo_root="$(git rev-parse --show-toplevel)"
tag_script="$repo_root/scripts/commit_scope_tags.sh"

if [[ ! -x "$tag_script" ]]; then
  exit 0
fi

subject="$(sed -n '1p' "$msg_file")"
case "$subject" in
  fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

required_tags="$("$tag_script")"
if [[ -z "$required_tags" ]]; then
  exit 0
fi

new_prefix=""
for tag in $required_tags; do
  if [[ "$subject" != *"$tag"* ]]; then
    new_prefix+="$tag"
  fi
done

if [[ -z "$new_prefix" ]]; then
  exit 0
fi

tmp_file="$(mktemp)"
{
  printf '%s %s\n' "$new_prefix" "$subject"
  sed -n '2,$p' "$msg_file"
} > "$tmp_file"
mv "$tmp_file" "$msg_file"
