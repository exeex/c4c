#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?missing commit message file}"
source_type="${2-}"

repo_root="$(git rev-parse --show-toplevel)"
tag_script="$repo_root/scripts/commit_scope_tags.sh"

if [[ ! -x "$tag_script" ]]; then
  exit 0
fi

subject="$(sed -n '1p' "$msg_file")"
case "$subject" in
  fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

required_tag="$("$tag_script")"
if [[ -z "$required_tag" ]]; then
  exit 0
fi

if [[ "$subject" == *"$required_tag"* ]]; then
  exit 0
fi

tmp_file="$(mktemp)"
{
  printf '%s %s\n' "$required_tag" "$subject"
  sed -n '2,$p' "$msg_file"
} > "$tmp_file"
mv "$tmp_file" "$msg_file"
